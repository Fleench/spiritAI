# SpiritAI RTX PRO 4500 Training Configuration
# Environment setup for a 5-10 hour "Set and Forget" overnight run.

# --- Paths ---
WORKSPACE_PATH="./data"

# --- Architecture (Optimized for 32GB VRAM) ---
N_EMBD=512
N_HEAD=8
N_LAYER=12
BLOCK_SIZE=256
DROPOUT=0.2
BIAS=false

# --- Training Hyperparameters ---
# Higher batch size for smoother gradients on the 4500
BATCH_SIZE=64
# Higher max_iters to keep the GPU busy for 10 hours
MAX_ITERS=500000
EVAL_INTERVAL=500
EVAL_ITERS=100

# --- Learning Rate (Cosine Decay Schedule) ---
LEARNING_RATE=3e-4
MIN_LR=1e-5
WEIGHT_DECAY=0.1
BETA1=0.9
BETA2=0.95
GRAD_CLIP=1.0

# --- Chat/Inference Settings ---
MAX_NEW_TOKENS=160
TEMPERATURE=0.8
TOP_K=50
REPETITION_PENALTY=1.15

# --- Run Safety & Technical ---
DTYPE="bfloat16"
COMPILE=true
RESUME=true
ALWAYS_SAVE_CHECKPOINT=true
CHECKPOINT_INTERVAL_SECONDS=900
MAX_TRAINING_HOURS=10
MIN_FREE_DISK_GB=2
SEED=1337

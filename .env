# ============================================================================
# NANO-GPT CONFIGURATION (RTX 5090 Optimized)
# ============================================================================

# HYPERPARAMETERS - Training
BATCH_SIZE=64       # Doubled: 5090 handles larger batches easily
BLOCK_SIZE=512      # Doubled: Allows the model to remember longer verses
MAX_ITERS=10000     # Higher quality steps (monitor val loss)
LEARNING_RATE=3e-4

# HYPERPARAMETERS - Model Architecture (This is where the "smartness" comes from)
N_EMBD=768          # Tripled: Much more space to store complex concepts
N_HEAD=12           # More heads to "look" at grammar and context simultaneously
N_LAYER=12          # Doubled: More layers for deeper reasoning
